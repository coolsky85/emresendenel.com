---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout
  title="Projects & Experience | Emre Sendenel"
  description="A detailed overview of Emre Sendenel's professional footprint — from large-scale IT infrastructure PMO to digital product delivery and personal app development."
>
  <section class="section-padding">
    <div class="container-content">
      <!-- Header -->
      <div class="mb-16 animate-fade-up">
        <h1 class="font-display text-[40px] md:text-hero font-bold text-text-primary mb-4">
          Projects & Experience
        </h1>
        <p class="text-body text-text-secondary max-w-xl">
          A detailed overview of my professional experience and personal projects.
        </p>
      </div>

      <!-- Professional Experience -->
      <div class="mb-20">
        <h2 class="font-display text-h2 text-text-primary mb-10 animate-fade-up" style="animation-delay: 0.1s;">
          Professional Experience
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
          <ProjectCard
            title="CONET Services GmbH"
            role="Project Manager"
            period="Apr 2022 – Present"
            tags={['IT Consulting', 'Project Management', 'PMO', 'Cross-functional Teams']}
            status="Current"
            statusType="current"
            description="Leading IT projects within the Consulting & Management division. Responsibilities span full project lifecycle: planning, controlling, quality management, stakeholder communication, on/offboarding, and training coordination across client engagements."
            logo="/images/logos/conet.svg"
            logoAlt="CONET Services logo"
          />
          <ProjectCard
            title="Public Sector — IT Infrastructure (Bonn)"
            role="Project Manager"
            period="Jun 2022 – Dec 2024"
            tags={['Public Sector', 'IT Infrastructure', 'PMO', 'Government']}
            status="Completed"
            statusType="completed"
            description="PMO and project management for a confidential large-scale government IT project in Bonn. Managed data center build-out and full-service operations under a multi-year public sector contract."
            logo="/images/logos/public-sector.png"
            logoAlt="Public sector project"
          />
          <ProjectCard
            title="Public Sector — IT Systems Support"
            role="Project Manager"
            period="Jun 2023 – Mar 2024"
            tags={['Public Sector', 'Server Infrastructure', 'Virtualization', 'IT Operations']}
            status="Completed"
            statusType="completed"
            description="Supported IT infrastructure operations including server management, SAN infrastructure, and client systems. Responsible for testing and commissioning of new services within a complex public sector IT environment."
            logo="/images/logos/public-sector.png"
            logoAlt="Public sector project"
          />
          <ProjectCard
            title="Doğuş Automotive — VW Car Configurator (iHDCC)"
            role="Key Account Manager / Project Manager"
            period="May 2016 – Apr 2017"
            tags={['Automotive', 'Digital Product', 'VW', 'Project Management']}
            status="Completed"
            statusType="completed"
            description="Led the Turkish market implementation of Volkswagen AG's global Internet High Definition Car Configurator (iHDCC). Managed interface coordination between VW AG and Doğuş Automotive, overseeing controlling and full delivery. Product live at vw.com.tr."
            logo="/images/logos/dogus.jpg"
            logoAlt="Doğuş Automotive logo"
          />
          <ProjectCard
            title="Doğuş Automotive — ERP System Integration (NADIN/Turkuaz)"
            role="Project Manager"
            period="Mar 2015 – Feb 2016"
            tags={['Automotive', 'ERP', 'System Integration', 'IT']}
            status="Completed"
            statusType="completed"
            description="Managed integration of outsourced programs (NADIN) into the proprietary ERP system (Turkuaz). Oversaw controlling, interface management, and end-to-end project execution across a 200-day engagement."
            logo="/images/logos/dogus.jpg"
            logoAlt="Doğuş Automotive logo"
          />
          <ProjectCard
            title={'Doğuş Automotive — "Which Volkswagen?" Video Campaign'}
            role="Project Manager"
            period="Mar 2017 – Jun 2017"
            tags={['Automotive', 'Digital Content', 'Campaign Management']}
            status="Completed"
            statusType="completed"
            description="Delivered an online video comparison series to guide customers in selecting their next Volkswagen model. Managed full project lifecycle from creative brief to YouTube publication as a branded product series."
            logo="/images/logos/dogus.jpg"
            logoAlt="Doğuş Automotive logo"
          />
        </div>
      </div>

      <!-- Personal Projects -->
      <div class="section-divider pt-16">
        <h2 class="font-display text-h2 text-text-primary mb-10 reveal">
          Personal Projects
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
          <ProjectCard
            title="RTM — Road To Marathon"
            description="A marathon training companion app built web-first. Structured training plans, HealthKit integration, and post-run analytics for runners at every level."
            tags={['iOS App', 'Running', 'Product Management']}
            status="In Development"
            statusType="dev"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

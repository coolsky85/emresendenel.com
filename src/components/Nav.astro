---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-[#1E1E1E]"
  style="background: rgba(10,10,10,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <div class="container-content flex items-center justify-between h-[72px]">
    <!-- Logo -->
    <a href="/" class="font-display text-[22px] font-semibold text-text-primary hover:text-accent transition-colors duration-300">
      Emre Sendenel
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={href}
            class={`nav-link font-body text-[15px] font-medium pb-1 ${isActive ? 'active' : ''}`}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Mobile Hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-[5px] w-8 h-8 items-center justify-center relative z-50"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="menu-line w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
      <span class="menu-line w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
      <span class="menu-line w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
    </button>
  </div>
</header>

<!-- Mobile Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-bg/98 backdrop-blur-xl flex items-center justify-center
         opacity-0 pointer-events-none transition-opacity duration-300"
>
  <nav class="flex flex-col items-center gap-8" aria-label="Mobile navigation">
    {navLinks.map(({ href, label }) => {
      const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
      return (
        <a
          href={href}
          class={`font-display text-[32px] font-semibold transition-colors duration-300
                  ${isActive ? 'text-accent' : 'text-text-primary hover:text-accent'}`}
        >
          {label}
        </a>
      );
    })}
  </nav>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = toggle?.querySelectorAll('.menu-line');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));

    if (open) {
      menu?.classList.remove('opacity-0', 'pointer-events-none');
      menu?.classList.add('opacity-100', 'pointer-events-auto');
      if (lines) {
        lines[0].style.transform = 'rotate(45deg) translate(2px, 5px)';
        lines[1].style.opacity = '0';
        lines[2].style.transform = 'rotate(-45deg) translate(2px, -5px)';
      }
      document.body.style.overflow = 'hidden';
    } else {
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.classList.remove('opacity-100', 'pointer-events-auto');
      if (lines) {
        lines[0].style.transform = '';
        lines[1].style.opacity = '1';
        lines[2].style.transform = '';
      }
      document.body.style.overflow = '';
    }
  });
</script>

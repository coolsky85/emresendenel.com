---
interface Props {
  title: string;
  description: string;
  tags: string[];
  role?: string;
  period?: string;
  status?: string;
  statusType?: 'current' | 'completed' | 'dev';
  logo?: string;
  logoAlt?: string;
}

const {
  title,
  description,
  tags,
  role,
  period,
  status,
  statusType = 'completed',
  logo,
  logoAlt = '',
} = Astro.props;

const dotClass = statusType === 'current'
  ? 'dot dot--current'
  : statusType === 'dev'
    ? 'dot dot--dev'
    : 'dot dot--completed';
---

<div class="card group cursor-default">
  <!-- Logo / Image -->
  {logo ? (
    <div class="w-full h-40 rounded-md mb-5 bg-surface-elevated flex items-center justify-center overflow-hidden">
      <img
        src={logo}
        alt={logoAlt}
        class="max-w-[70%] max-h-[80%] object-contain"
        loading="lazy"
        width="200"
        height="100"
      />
    </div>
  ) : (
    <div class="w-full h-40 rounded-md mb-5 bg-surface-elevated flex items-center justify-center">
      <span class="text-text-secondary/30 font-display text-[32px] font-bold select-none">
        {title.split(' ').map(w => w[0]).join('').slice(0, 3)}
      </span>
    </div>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="font-body text-h3 text-text-primary mb-1">{title}</h3>

  <!-- Role & Period -->
  {(role || period) && (
    <div class="mb-3 text-[14px] font-medium text-text-secondary flex flex-wrap gap-x-2 items-center">
      {role && <span class="text-accent">{role}</span>}
      {role && period && <span class="text-border-hover">·</span>}
      {period && <span>{period}</span>}
    </div>
  )}

  <!-- Description -->
  <p class="text-[15px] text-text-secondary leading-relaxed mb-4">{description}</p>

  <!-- Status -->
  {status && (
    <div class="flex items-center justify-between">
      <span class="status-chip">
        <span class={dotClass}></span>
        {status}
      </span>
    </div>
  )}
</div>

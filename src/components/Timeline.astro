---
interface TimelineEntry {
  role: string;
  company: string;
  period: string;
  description: string;
  isCurrent?: boolean;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<div class="relative pl-8">
  <!-- Vertical line -->
  <div class="absolute left-[7px] top-2 bottom-2 w-[1px] bg-accent/30"></div>

  {entries.map((entry, i) => (
    <div class={`relative pb-10 last:pb-0 group`}>
      <!-- Dot -->
      <div
        class={`absolute left-[-25px] top-[6px] w-[15px] h-[15px] rounded-full border-2
                ${entry.isCurrent
                  ? 'bg-accent border-accent shadow-[0_0_8px_rgba(200,169,110,0.4)]'
                  : 'bg-bg border-accent/40 group-hover:border-accent transition-colors duration-300'
                }`}
      ></div>

      <!-- Content -->
      <div>
        <h3 class="font-body text-[18px] font-medium text-text-primary mb-1">
          {entry.role}
        </h3>
        <p class="text-[14px] text-accent font-medium mb-1">
          {entry.company}
        </p>
        <p class="text-meta text-text-secondary mb-2 uppercase tracking-wider">
          {entry.period}
        </p>
        <p class="text-[15px] text-text-secondary leading-relaxed">
          {entry.description}
        </p>
      </div>
    </div>
  ))}
</div>

---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col sm:flex-row gap-4 sm:gap-8 py-6 border-b border-border
         hover:border-border-hover transition-colors duration-300"
>
  <!-- Date -->
  <span class="text-meta text-text-secondary shrink-0 sm:w-28 uppercase tracking-wider pt-1">
    {formattedDate}
  </span>

  <!-- Content -->
  <div class="flex-1">
    <h3 class="font-body text-[20px] font-medium text-text-primary group-hover:text-accent transition-colors duration-300 mb-1">
      {title}
    </h3>
    <p class="text-[15px] text-text-secondary leading-relaxed mb-3">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <!-- Arrow -->
  <div class="hidden sm:flex items-center shrink-0">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      class="text-text-secondary group-hover:text-accent group-hover:translate-x-1 transition-all duration-300"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </div>
</a>
